/* ── Import / Export ────────────────────────────────────── */
function openImport()  { document.getElementById('import-modal').classList.add('show'); }
function closeImport() { document.getElementById('import-modal').classList.remove('show'); }

function doImport() {
  const raw = document.getElementById('import-textarea').value.trim();
  if (!raw) { showToast('請貼上資料', 'error'); return; }
  const lines = raw.split(/\r?\n/).filter(l => l.trim());
  let count = 0;
  lines.forEach(line => {
    const parts = line.split(/,|\t/).map(p => p.trim());
    if (parts.length >= 3) {
      addRow({
        station:  parts[0],
        start:    parts[1],
        end:      parts[2],
        progress: parseInt(parts[3])||0,
        note:     parts[4]||''
      });
      count++;
    }
  });
  closeImport();
  if (count) { renderGantt(); showToast(`已匯入 ${count} 筆資料`, 'success'); }
  else showToast('格式有誤，請確認資料格式', 'error');
}

function exportCSV() {
  getRowValues();
  if (!rows.length) { showToast(i18n.toast_no_data, 'error'); return; }
  const header = '站點名稱,起始日期,Due Date,進度%,備註\n';
  const body   = rows.map(r => `${r.station},${r.start},${r.end},${r.progress},${r.note}`).join('\n');
  const blob   = new Blob(['\uFEFF'+header+body], { type: 'text/csv;charset=utf-8;' });
  const url    = URL.createObjectURL(blob);
  const a      = document.createElement('a');
  a.href = url; a.download = `GanttData_${fmtFull(today()).replace(/\//g,'')}.csv`;
  a.click(); URL.revokeObjectURL(url);
  showToast(i18n.toast_csv_exported, 'success');
}

/* ── Export PNG ──────────────────────────────────────────── */
function exportPNG() {
  const ganttTbl = document.getElementById('gantt-tbl');
  if (!ganttTbl) { showToast(i18n.toast_no_gantt, 'error'); return; }

  // 動態載入 html2canvas
  if (typeof html2canvas === 'undefined') {
    const s = document.createElement('script');
    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js';
    s.onload = () => _doExportPNG();
    s.onerror = () => showToast(i18n.toast_png_lib_fail, 'error');
    document.head.appendChild(s);
    showToast(i18n.toast_png_loading, 'info');
  } else {
    _doExportPNG();
  }
}

function _doExportPNG() {
  const panel = document.getElementById('gantt-panel');
  const tbl   = document.getElementById('gantt-tbl');
  if (!tbl) { showToast(i18n.toast_no_gantt, 'error'); return; }

  showToast(i18n.toast_png_rendering, 'info');

  // Render the full panel at full scroll width (no clipping)
  const fullW = panel.scrollWidth;
  const fullH = panel.scrollHeight;
  const PAGE_W = 1600; // logical pixels per page slice
  const totalPages = Math.ceil(fullW / PAGE_W);

  html2canvas(panel, {
    backgroundColor: '#ffffff',
    scale: 2,
    useCORS: true,
    scrollX: 0,
    scrollY: -window.scrollY,
    windowWidth:  fullW + 40,
    windowHeight: fullH + 40,
    width:  fullW,
    height: fullH,
    x: 0,
    y: 0,
  }).then(fullCanvas => {
    const dateStr = fmtFull(today()).replace(/\//g,'');
    if (totalPages === 1) {
      // Single page — download directly
      const a = document.createElement('a');
      a.href = fullCanvas.toDataURL('image/png');
      a.download = `GanttChart_${dateStr}.png`;
      a.click();
      showToast(i18n.toast_png_exported, 'success');
    } else {
      // Multi-page — slice the full canvas horizontally
      const scale = fullCanvas.width / fullW; // actual pixel ratio (scale * devicePixelRatio)
      const sliceW = Math.round(PAGE_W * scale);
      const totalSlices = Math.ceil(fullCanvas.width / sliceW);

      for (let p = 0; p < totalSlices; p++) {
        const sx = p * sliceW;
        const sw = Math.min(sliceW, fullCanvas.width - sx);
        const slice = document.createElement('canvas');
        slice.width  = sw;
        slice.height = fullCanvas.height;
        const ctx = slice.getContext('2d');
        ctx.drawImage(fullCanvas, sx, 0, sw, fullCanvas.height, 0, 0, sw, fullCanvas.height);
        const a = document.createElement('a');
        a.href = slice.toDataURL('image/png');
        a.download = `GanttChart_${dateStr}_p${p+1}of${totalSlices}.png`;
        // Stagger downloads slightly to avoid browser blocking
        setTimeout(() => a.click(), p * 300);
      }
      setTimeout(() => showToast(
        (i18n.toast_png_pages || 'PNG exported ({n} pages)').replace('{n}', totalSlices),
        'success'
      ), totalSlices * 300);
    }
  }).catch(err => {
    console.error(err);
    showToast(i18n.toast_png_fail, 'error');
  });
}

