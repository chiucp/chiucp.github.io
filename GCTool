function applyI18n() {
  const L = i18n;
  // Top bar title
  document.querySelector('.topbar-title').textContent  = L.title;
  document.querySelector('.topbar-subtitle').textContent = L.subtitle;
  document.getElementById('lang-btn').textContent = currentLang === 'zh' ? 'EN' : '中文';

