<!-- ════════════════════════════════════════════════════════
     JAVASCRIPT
════════════════════════════════════════════════════════ -->
<script>
/* ── Constants ──────────────────────────────────────────── */
const BAR_COLORS = [
  '#4472C4','#3CB371','#ED7D31','#C00000',
  '#7030A0','#00B0A0','#D4A017','#E75480',
  '#1F6B75','#8B4513','#2E8B57','#B8860B'
];

const WEEKDAY_NAMES_ZH = ['日','一','二','三','四','五','六'];
const WEEKDAY_NAMES_EN = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const MONTH_NAMES_ZH   = ['1月','2月','3月','4月','5月','6月','7月','8月','9月','10月','11月','12月'];
const MONTH_NAMES_EN   = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const getWeekdayNames  = () => currentLang === 'en' ? WEEKDAY_NAMES_EN : WEEKDAY_NAMES_ZH;
const getMonthNames    = () => currentLang === 'en' ? MONTH_NAMES_EN   : MONTH_NAMES_ZH;

let autoRender = false;
let rows = [];
let nextId = 1;

/* ── Date Helpers ───────────────────────────────────────── */
const parseDate = s => {
  if (!s) return null;
  const d = new Date(s.replace(/\//g,'-'));
  return isNaN(d) ? null : new Date(d.getFullYear(), d.getMonth(), d.getDate());
};
const addDays  = (d, n) => { const r = new Date(d); r.setDate(r.getDate()+n); return r; };
const addDaysStr = (s, n) => { if(!s) return ''; const d = new Date(s); if(isNaN(d)) return ''; d.setDate(d.getDate()+n); return d.toISOString().slice(0,10); };
const calcDuration = (s, e) => { const a=new Date(s), b=new Date(e); if(isNaN(a)||isNaN(b)||b<a) return ''; return Math.round((b-a)/86400000)+1; };
const diffDays = (a, b) => Math.round((b-a)/86400000);
const isWeekend = d => d.getDay()===0 || d.getDay()===6;
const fmtDate  = (d, fmt) => {
  if (fmt==='d')   return String(d.getDate());
  if (fmt==='mdd') return `${String(d.getMonth()+1).padStart(2,'0')}/${String(d.getDate()).padStart(2,'0')}`;
  return `${d.getMonth()+1}/${d.getDate()}`;
};
const fmtFull  = d => `${d.getFullYear()}/${String(d.getMonth()+1).padStart(2,'0')}/${String(d.getDate()).padStart(2,'0')}`;
const today    = () => { const d=new Date(); return new Date(d.getFullYear(),d.getMonth(),d.getDate()); };

/* ── Row Management ─────────────────────────────────────── */
function addRow(data={}) {
  const id = nextId++;
  const dur = (data.start && data.end) ? calcDuration(data.start, data.end) : (data.duration||'');
  rows.push({ id, station: data.station||'', start: data.start||'', end: data.end||'', duration: dur, progress: data.progress||0, note: data.note||'' });
  renderTable();
  if (autoRender) renderGantt();
}

function removeRow(id) {
  rows = rows.filter(r => r.id !== id);
  renderTable();
  if (autoRender) renderGantt();
}

function getRowValues() {
  // sync from DOM
  rows.forEach(r => {
    const tr = document.querySelector(`tr[data-id="${r.id}"]`);
    if (!tr) return;
    r.station  = tr.querySelector('.inp-station').value.trim();
    r.start    = tr.querySelector('.inp-start').value;
    r.end      = tr.querySelector('.inp-end').value;
    r.duration = parseInt(tr.querySelector('.inp-duration').value)||'';
    r.progress = parseInt(tr.querySelector('.inp-progress').value)||0;
    r.note     = tr.querySelector('.inp-note').value.trim();
  });
}

function renderTable() {
  const tbody = document.getElementById('input-tbody');
  tbody.innerHTML = '';
  rows.forEach((r, i) => {
    const tr = document.createElement('tr');
    tr.dataset.id = r.id;
    tr.innerHTML = `
      <td class="td-num">${i+1}</td>
      <td><input type="text" class="inp-station" placeholder="站點名稱" value="${esc(r.station)}" oninput="onInput(${r.id},'station',this.value)"></td>
      <td><div class="date-wrap"><button type="button" class="date-cal-btn" onclick="this.nextElementSibling.showPicker()" tabindex="-1">&#128197;</button><input type="date" class="inp-start" value="${toDateInput(r.start)}" oninput="onInput(${r.id},'start',this.value)"></div></td>
      <td><div class="date-wrap"><button type="button" class="date-cal-btn" onclick="this.nextElementSibling.showPicker()" tabindex="-1">&#128197;</button><input type="date" class="inp-end"   value="${toDateInput(r.end)}"   oninput="onInput(${r.id},'end',this.value)"></div></td>
      <td><input type="number" class="inp-duration" min="1" value="${r.duration||''}" placeholder="-" style="width:64px;padding:9px 8px;text-align:center;" oninput="onInput(${r.id},'duration',this.value)"></td>
      <td><input type="number" class="inp-progress" min="0" max="100" value="${r.progress}" style="width:70px;padding:9px 8px;" oninput="onInput(${r.id},'progress',this.value)"></td>
      <td><input type="text" class="inp-note"    placeholder="備註（選填）" value="${esc(r.note)}" oninput="onInput(${r.id},'note',this.value)"></td>
      <td class="td-action"><button class="del-btn" onclick="removeRow(${r.id})" title="刪除">✕</button></td>`;
    tbody.appendChild(tr);
  });
}

function onInput(id, field, value) {
  const r = rows.find(r => r.id === id);
  if (!r) return;

  if (field === 'progress') {
    r.progress = parseInt(value)||0;
  } else if (field === 'station' || field === 'note') {
    r[field] = value;
  } else if (field === 'start') {
    r.start = value;
    if (value && r.end) {
      // start changed → recalc duration
      r.duration = calcDuration(value, r.end);
    } else if (value && r.duration) {
      // start changed, no end → derive end from duration
      r.end = addDaysStr(value, Number(r.duration) - 1);
    }
    // update DOM without full re-render
    _syncDurationDOM(id, r);
  } else if (field === 'end') {
    r.end = value;
    if (r.start && value) {
      // end changed → recalc duration
      r.duration = calcDuration(r.start, value);
    }
    _syncDurationDOM(id, r);
  } else if (field === 'duration') {
    const d = parseInt(value);
    r.duration = isNaN(d) || d < 1 ? '' : d;
    if (r.start && r.duration) {
      // duration changed + start exists → derive end
      r.end = addDaysStr(r.start, Number(r.duration) - 1);
      _syncEndDOM(id, r);
    } else if (r.end && r.duration) {
      // duration changed + end exists, no start → derive start
      r.start = addDaysStr(r.end, -(Number(r.duration) - 1));
      _syncStartDOM(id, r);
    }
  }

  if (autoRender) renderGantt();
}

function _syncDurationDOM(id, r) {
  const tr = document.querySelector(`tr[data-id="${id}"]`);
  if (!tr) return;
  const inp = tr.querySelector('.inp-duration');
  if (inp && document.activeElement !== inp) inp.value = r.duration||'';
  const endInp = tr.querySelector('.inp-end');
  if (endInp && document.activeElement !== endInp) endInp.value = toDateInput(r.end);
}
function _syncEndDOM(id, r) {
  const tr = document.querySelector(`tr[data-id="${id}"]`);
  if (!tr) return;
  const inp = tr.querySelector('.inp-end');
  if (inp && document.activeElement !== inp) inp.value = toDateInput(r.end);
}
function _syncStartDOM(id, r) {
  const tr = document.querySelector(`tr[data-id="${id}"]`);
  if (!tr) return;
  const inp = tr.querySelector('.inp-start');
  if (inp && document.activeElement !== inp) inp.value = toDateInput(r.start);
}

function toDateInput(s) {
  if (!s) return '';
  return s.replace(/\//g,'-');
}

function esc(s) {
  return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

/* ── Gantt Render ───────────────────────────────────────── */
function renderGantt() {
  getRowValues();

  const validRows = rows.filter(r => r.station && parseDate(r.start) && parseDate(r.end));
  if (!validRows.length) {
    clearGantt();
    showToast('請至少輸入一筆完整資料（站點 + 起始日期 + Due Date）', 'error');
    return;
  }

  // Validate
  let hasError = false;
  validRows.forEach(r => {
    const s = parseDate(r.start), e = parseDate(r.end);
    if (s > e) { showToast(`「${r.station}」的起始日期晚於截止日期`, 'error'); hasError = true; }
  });
  if (hasError) return;

  const colW  = parseInt(document.getElementById('col-width').value)  || 28;
  const rowH  = parseInt(document.getElementById('row-height').value) || 36;
  const dateFmt      = document.getElementById('date-fmt').value;
  const showProgress = document.getElementById('show-progress').checked;
  const showLabel    = document.getElementById('show-label').checked;
  const showWeekend  = document.getElementById('show-weekend').checked;

  const minDate = new Date(Math.min(...validRows.map(r => parseDate(r.start))));
  const maxDate = new Date(Math.max(...validRows.map(r => parseDate(r.end))));
  const todayD  = today();

  // Build date list (optionally skip weekends)
  let dates = [];
  let d = new Date(minDate);
  while (d <= maxDate) {
    if (showWeekend || !isWeekend(d)) dates.push(new Date(d));
    d = addDays(d, 1);
  }

  // Date → col index map
  const dateColMap = {};
  dates.forEach((dd, i) => { dateColMap[fmtFull(dd)] = i; });

  // Stats
  const totalDays = diffDays(minDate, maxDate) + 1;
  const avgProgress = validRows.length ? Math.round(validRows.reduce((s,r)=>s+r.progress,0)/validRows.length) : 0;
  const overdueCount = validRows.filter(r => parseDate(r.end) < todayD && r.progress < 100).length;

  document.getElementById('stat-count').textContent   = validRows.length;
  document.getElementById('stat-days').textContent    = totalDays;
  document.getElementById('stat-done').textContent    = avgProgress + '%';
  document.getElementById('stat-overdue').textContent = overdueCount;
  document.getElementById('stat-today').textContent   = fmtFull(todayD);
  document.getElementById('stats-bar').style.display  = 'flex';
  document.getElementById('gantt-date-range').textContent = `${fmtFull(minDate)} ～ ${fmtFull(maxDate)}`;

  // ── Build Table HTML ──────────────────────────────────
  let html = `<table class="gantt-table" id="gantt-tbl" style="--col-w:${colW}px;--row-h:${rowH}px;">`;

  // Month header row
  html += '<tr>';
  html += `<th class="gl-month-header" style="height:26px;"></th>`;
  let mi = 0;
  while (mi < dates.length) {
    const m = dates[mi].getMonth();
    const y = dates[mi].getFullYear();
    let span = 0;
    while (mi + span < dates.length && dates[mi+span].getMonth() === m) span++;
    const MONTH_NAMES = getMonthNames();
    html += `<th class="gh-month" colspan="${span}" style="min-width:${colW*span}px;">${currentLang==='en' ? MONTH_NAMES[m]+' '+y : y+'年 '+MONTH_NAMES[m]}</th>`;
    mi += span;
  }
  html += '</tr>';

  // Day header row
  html += '<tr>';
  html += `<th class="gl-header" style="height:28px;">${i18n.gantt_header||'站點 / 日期'}</th>`;
  dates.forEach(dd => {
    const isToday = dd.getTime() === todayD.getTime();
    const wknd = isWeekend(dd);
    let cls = wknd ? 'weekend' : 'workday';
    if (isToday) cls = 'today-hd';
    const wdName = getWeekdayNames()[dd.getDay()];
    html += `<th class="gh-day ${cls}" style="width:${colW}px;min-width:${colW}px;" title="${fmtFull(dd)} (${wdName})">${fmtDate(dd,dateFmt)}</th>`;
  });
  html += '</tr>';

  // Data rows
  validRows.forEach((r, ri) => {
    const color    = BAR_COLORS[ri % BAR_COLORS.length];
    const sDate    = parseDate(r.start);
    const eDate    = parseDate(r.end);
    const sCol     = dateColMap[fmtFull(sDate)];
    const eCol     = dateColMap[fmtFull(eDate)];
    const span     = (eCol !== undefined && sCol !== undefined) ? (eCol - sCol + 1) : 0;
    const isOverdue = eDate < todayD && r.progress < 100;
    const barColor  = color;  // keep original color regardless of overdue
    const labelText = showLabel && span >= 3 ? esc(r.station) : '';
    const progW     = showProgress ? `${r.progress}%` : '0%';
    const glStyle   = isOverdue ? `height:${rowH}px;color:#C00000;font-weight:700;` : `height:${rowH}px;`;

    html += `<tr class="today-line-row" style="height:${rowH}px;">`;
    html += `<td class="gl" style="${glStyle}" title="${esc(r.station)}${r.note ? ' — '+esc(r.note) : ''}">${esc(r.station)}</td>`;

    dates.forEach((dd, di) => {
      const isToday = dd.getTime() === todayD.getTime();
      const wknd = isWeekend(dd);
      let cls = 'gc';
      if (wknd) cls += ' weekend-col';
      if (isToday) cls += ' today-col';

      let inner = '';
      if (sCol !== undefined && di === sCol && span > 0) {
        const barW = `calc(${span * colW}px - 2px)`;
        const noteAttr = r.note ? esc(r.note) : '';
        inner = `<div class="gantt-bar"
          style="background:${barColor};width:${barW};left:1px;"
          data-station="${esc(r.station)}"
          data-start="${fmtFull(sDate)}"
          data-end="${fmtFull(eDate)}"
          data-progress="${r.progress}"
          data-note="${noteAttr}"
          data-days="${diffDays(sDate,eDate)+1}"
          onmouseenter="showTip(event,this)"
          onmouseleave="hideTip()"
          onmousemove="moveTip(event)">
          <div class="bar-progress" style="width:${progW};"></div>
          <span style="position:relative;z-index:1;">${labelText}</span>
        </div>`;
      }
      html += `<td class="${cls}" style="width:${colW}px;min-width:${colW}px;height:${rowH}px;">${inner}</td>`;
    });

    html += '</tr>';
  });

  html += '</table>';

  const container = document.getElementById('gantt-container');
  container.classList.remove('empty');
  container.innerHTML = html;

  // Legend
  const legend = document.getElementById('gantt-legend');
  legend.style.display = 'flex';
  legend.innerHTML = validRows.map((r, ri) => {
    const color = BAR_COLORS[ri % BAR_COLORS.length];
    const eDate = parseDate(r.end);
    const isOverdue = eDate < todayD && r.progress < 100;
    const textStyle = isOverdue ? 'color:#C00000;font-weight:700;' : '';
    return `<div class="legend-item" onclick="toggleLegend(${ri})" id="legend-${ri}" title="${esc(r.station)}">
      <div class="legend-dot" style="background:${color};"></div>
      <span style="${textStyle}">${esc(r.station)}</span>
    </div>`;
  }).join('') +
  `<div class="legend-item"><div class="legend-dot" style="background:#8899AA;"></div><span>${i18n.legend_weekend||'週末'}</span></div>` +
  (todayD >= minDate && todayD <= maxDate ? `<div class="legend-item"><div class="legend-dot" style="background:#C00000;border-radius:50%;"></div><span>${i18n.legend_today||'今日'}</span></div>` : '') +
  (overdueCount > 0 ? `<div class="legend-item"><div class="legend-dot" style="background:#C00000;"></div><span>${i18n.legend_overdue||'逾期'}</span></div>` : '');

  showToast((i18n.toast_gantt_done||'甘特圖已產生').replace('{n}', validRows.length).replace('{d}', totalDays), 'success');
}

/* ── Tooltip ────────────────────────────────────────────── */
const tooltip = document.getElementById('tooltip');
function showTip(e, el) {
  const s = el.dataset.station;
  const st = el.dataset.start;
  const en = el.dataset.end;
  const pr = el.dataset.progress;
  const nt = el.dataset.note;
  const dy = el.dataset.days;
  tooltip.innerHTML = `<strong>${s}</strong><br>
    ${i18n.tip_start||'起始'}：${st}<br>${i18n.tip_end||'截止'}：${en}<br>
    ${i18n.tip_days||'工期'}：${dy} ${i18n.tip_days_unit||'天'}<br>${i18n.tip_progress||'進度'}：${pr}%
    ${nt ? `<br>${i18n.tip_note||'備註'}：${nt}` : ''}`;
  tooltip.classList.add('show');
  moveTip(e);
}
function moveTip(e) {
  const x = e.clientX + 14, y = e.clientY - 10;
  tooltip.style.left = Math.min(x, window.innerWidth - 260) + 'px';
  tooltip.style.top  = Math.max(y, 8) + 'px';
}
function hideTip() { tooltip.classList.remove('show'); }

/* ── Legend Toggle ──────────────────────────────────────── */
function toggleLegend(ri) {
  const el = document.getElementById(`legend-${ri}`);
  el.classList.toggle('dimmed');
  // find all bars for this row (by index)
  const bars = document.querySelectorAll('.gantt-bar');
  let barIdx = 0;
  bars.forEach(b => {
    if (barIdx === ri) b.style.opacity = el.classList.contains('dimmed') ? '0.15' : '1';
    barIdx++;
  });
}

