  const labelKeys = ['lbl_col_width','lbl_row_height','lbl_date_fmt','lbl_show_progress','lbl_show_label','lbl_show_weekend'];
  settingLabels.forEach((el, i) => { if (L[labelKeys[i]]) el.textContent = L[labelKeys[i]]; });

  // Action bar buttons
  const genBtn     = document.querySelector('.action-bar .btn-primary');
  const clearGBtn  = document.querySelector('.action-bar .btn-warn');
  const todayBtn   = document.querySelector('.action-bar .btn-outline');
  if (genBtn)    genBtn.textContent    = L.btn_generate;
  if (clearGBtn) clearGBtn.textContent = L.btn_clear_gantt;
  if (todayBtn)  todayBtn.textContent  = L.btn_goto_today;

  // Auto btn
  updateAutoBtn();

  // Gantt panel title
  const ganttTitle = document.querySelector('#gantt-panel .panel-title');
  if (ganttTitle) ganttTitle.childNodes[ganttTitle.childNodes.length-1].textContent = ' ' + L.panel_gantt;

  // Stats labels
  const statLabels = document.querySelectorAll('.stat-label');
  const statKeys   = ['stat_count','stat_days','stat_done','stat_overdue','stat_today'];
  statLabels.forEach((el, i) => { if (L[statKeys[i]]) el.textContent = L[statKeys[i]]; });

  // Empty gantt message
  const emptyDiv = document.querySelector('#gantt-container.empty > div:last-child');
  if (emptyDiv) emptyDiv.textContent = L.empty_msg;

  // Input placeholders in table
  document.querySelectorAll('.inp-station').forEach(el => el.placeholder = L.inp_station_ph);
  document.querySelectorAll('.inp-note').forEach(el => el.placeholder = L.inp_note_ph);

  // Paste panel collapse button
  const collapseBtn = document.querySelector('#paste-panel .panel-header button');
  if (collapseBtn) collapseBtn.innerHTML = pastePanelOpen ? L.paste_collapse : L.paste_expand;
  // Paste panel hint span (the '(可收起)' one — it's the first span in the right-side div)
  const collapseHint = document.querySelector('#paste-panel .panel-header > div:last-child > span');
  if (collapseHint) collapseHint.textContent = L.paste_can_collapse;
}

/* ── Toast ──────────────────────────────────────────────── */
function showToast(msg, type='info') {
  const c = document.getElementById('toast-container');
  const t = document.createElement('div');
  t.className = `toast ${type}`;
  const icons = { success:'✅', error:'❌', info:'ℹ️' };
  t.innerHTML = `<span>${icons[type]||''}</span><span>${msg}</span>`;
  c.appendChild(t);
  setTimeout(() => { t.style.opacity='0'; t.style.transform='translateX(60px)'; t.style.transition='all .3s'; setTimeout(()=>t.remove(),350); }, 2800);
}

/* ── Excel Paste & Parse ────────────────────────────────── */

let rawPastedRows  = [];   // raw 2D array from clipboard
let rawHeaders     = [];   // detected header row (may be empty)
let parsedPreview  = [];   // [{station, start, end, status}]
let pastePanelOpen = true;

// 收起/展開貼上區
function togglePastePanel() {
  pastePanelOpen = !pastePanelOpen;
  const body = document.getElementById('paste-panel-body');
  const btn  = document.querySelector('#paste-panel .panel-header button');
  body.style.display = pastePanelOpen ? '' : 'none';
  btn.innerHTML = pastePanelOpen ? '&#x25B2; 收起' : '&#x25BC; 展開';
}

// 處理貼上事件
function handlePaste(e) {
  e.preventDefault();
  const cd = e.clipboardData || window.clipboardData;

  // 先嘗試取得 HTML 格式（Excel 貼上會包含 HTML 表格）
  const html = cd.getData('text/html');
  if (html && html.includes('<table')) {
    parseFromHTML(html);
    return;
  }
  // fallback: 純文字 tab-separated
  const text = cd.getData('text/plain');
  if (text) parseFromText(text);
}

function handleTextInput(e) {
  // 如果直接輸入文字也處理
  const val = e.target.value;
  if (val.trim()) { parseFromText(val); e.target.value = ''; }
}

// 從 HTML 表格剖析
function parseFromHTML(html) {
  const parser = new DOMParser();
  const doc    = parser.parseFromString(html, 'text/html');
  const trs    = doc.querySelectorAll('tr');
  if (!trs.length) { showToast('未偵測到表格資料', 'error'); return; }

  const data = [];
  trs.forEach(tr => {
    const cells = Array.from(tr.querySelectorAll('td,th')).map(td => {
      // 取得儲存格的文字，清除多餘空白
      return td.innerText.replace(/\n/g,' ').trim();
    });
    if (cells.some(c => c !== '')) data.push(cells);
  });

  rawPastedRows = data;
  detectAndRender();
}

// 從純文字剖析
function parseFromText(text) {
  const lines = text.split(/\r?\n/).filter(l => l.trim());
  rawPastedRows = lines.map(l => l.split('\t').map(c => c.trim()));
  detectAndRender();
}

// 自動偵測欄位並渲染預覽
function detectAndRender() {
  if (!rawPastedRows.length) return;

  // 偵測欄數
  const maxCols = Math.max(...rawPastedRows.map(r => r.length));
  if (maxCols < 1) { showToast('資料格式無法辨識', 'error'); return; }

  // 建立欄位選單
  const colOptions = Array.from({length: maxCols}, (_,i) => `第 ${i+1} 欄`);

  // 偵測是否有標題列：第一列如果不含日期格式，視為標題
  const firstRow = rawPastedRows[0];
  const hasHeader = !firstRow.some(c => looksLikeDate(c));
  rawHeaders = hasHeader ? firstRow : colOptions;

  // 建立欄位選單選項
  const selStation = document.getElementById('map-station');
  const selStart   = document.getElementById('map-start');
  const selEnd     = document.getElementById('map-end');

  [selStation, selStart, selEnd].forEach(sel => {
    sel.innerHTML = rawHeaders.map((h,i) => `<option value="${i}">${h||'(第 '+(i+1)+' 欄)'}</option>`).join('');
  });

  // 自動匹配欄位
  autoMapColumns(rawHeaders, hasHeader);

  document.getElementById('col-map-section').style.display = 'block';

  // 貼上區顯示有內容狀態
  const zone = document.getElementById('paste-zone');
  zone.classList.add('has-content');
  zone.style.minHeight = '48px';

  reparse();
}

// 自動匹配欄位名稱
function autoMapColumns(headers, hasHeader) {
  const h = headers.map(s => String(s).toLowerCase());

  const stationKw = ['station','task','name','站點','任務','名稱','項目'];
  const startKw   = ['begin','start','起始','開始','from'];
  const endKw     = ['end','due','finish','截止','結束','to'];

  const findCol = kws => {
    for (const kw of kws) {
      const idx = h.findIndex(s => s.includes(kw));
      if (idx >= 0) return idx;
    }
    return -1;
  };

  let si = findCol(stationKw);
  let bi = findCol(startKw);
  let ei = findCol(endKw);

  // 如果標題匹配失敗，用位置預設：第0欄為站點，第1欄為起始，第2欄為截止
  if (si < 0) si = 0;
  if (bi < 0) bi = Math.min(1, headers.length-1);
  if (ei < 0) ei = Math.min(2, headers.length-1);

  document.getElementById('map-station').value = si;
  document.getElementById('map-start').value   = bi;
  document.getElementById('map-end').value     = ei;
}

// 重新剖析（欄位對應變更時）
function reparse() {
  const si = parseInt(document.getElementById('map-station').value);
  const bi = parseInt(document.getElementById('map-start').value);
  const ei = parseInt(document.getElementById('map-end').value);

  // 判斷是否有標題列
  const firstRow = rawPastedRows[0];
  const hasHeader = !firstRow.some(c => looksLikeDate(c));
  const dataRows  = hasHeader ? rawPastedRows.slice(1) : rawPastedRows;

  parsedPreview = [];
  dataRows.forEach((row, idx) => {
    const station = (row[si]||'').trim();
    const startRaw = (row[bi]||'').trim();
    const endRaw   = (row[ei]||'').trim();

    const startD = parseExcelDate(startRaw);
    const endD   = parseExcelDate(endRaw);

    let status = 'ok';
    let hint   = '';

    if (!station && !startRaw && !endRaw) { status = 'skip'; hint = '空白列'; }
    else if (!station) { status = 'warn'; hint = '站點名稱為空'; }
    else if (!startD && !endD) { status = 'warn'; hint = '日期皆為空'; }
    else if (startD && endD && startD > endD) { status = 'warn'; hint = '起始 > 截止'; }

    parsedPreview.push({
      station, startRaw, endRaw,
      start: startD ? fmtFull(startD) : '',
      end:   endD   ? fmtFull(endD)   : '',
      status, hint
    });
  });

  renderPreview(hasHeader);
}

// 渲染預覽表格
function renderPreview(hasHeader) {
  const si = parseInt(document.getElementById('map-station').value);
  const bi = parseInt(document.getElementById('map-start').value);
  const ei = parseInt(document.getElementById('map-end').value);

  // 標題
  const thead = document.getElementById('preview-thead');
  thead.innerHTML = '<th>狀態</th><th>站點名稱</th><th>起始日期</th><th>截止日期</th><th>說明</th>';

  // 內容
  const tbody = document.getElementById('preview-tbody');
  tbody.innerHTML = '';
  parsedPreview.forEach(r => {
    const tr = document.createElement('tr');
    tr.className = r.status === 'ok' ? 'row-ok' : r.status === 'warn' ? 'row-warn' : 'row-skip';
    const statusIcon = r.status === 'ok' ? '<span style="color:var(--success);">&#x2714;</span>'
      : r.status === 'warn' ? '<span style="color:var(--accent);">&#x26A0;</span>'
      : '<span style="color:#CCC;">&#x2014;</span>';
    tr.innerHTML = `
      <td style="text-align:center;">${statusIcon}</td>
      <td class="td-station">${esc(r.station)||'<span class="td-empty">(空)</span>'}</td>
      <td class="td-date">${r.start || (r.startRaw ? `<span class="td-warn">${esc(r.startRaw)}</span>` : '<span class="td-empty">-</span>')}</td>
      <td class="td-date">${r.end   || (r.endRaw   ? `<span class="td-warn">${esc(r.endRaw)}</span>`   : '<span class="td-empty">-</span>')}</td>
      <td style="font-size:12px;color:var(--muted);">${r.hint}</td>`;
    tbody.appendChild(tr);
  });

  // 摘要
  const okCount   = parsedPreview.filter(r => r.status === 'ok').length;
  const warnCount = parsedPreview.filter(r => r.status === 'warn').length;
  const skipCount = parsedPreview.filter(r => r.status === 'skip').length;

  document.getElementById('parse-summary').innerHTML = `
    <div class="ps-item"><div class="ps-dot" style="background:var(--success);"></div>可匯入 ${okCount} 筆</div>
    ${warnCount ? `<div class="ps-item"><div class="ps-dot" style="background:var(--accent);"></div>有警告 ${warnCount} 筆（仍可匯入）</div>` : ''}
    ${skipCount ? `<div class="ps-item"><div class="ps-dot" style="background:#CCC;"></div>跳過 ${skipCount} 筆</div>` : ''}
  `;

  document.getElementById('apply-hint').textContent =
    okCount + warnCount > 0 ? '' : '沒有可匯入的資料，請檢查欄位對應設定';

  document.getElementById('paste-preview').style.display = 'block';
}

// 套用剖析結果至資料輸入
function applyParsed() {
  const toImport = parsedPreview.filter(r => r.status !== 'skip' && r.station);
  if (!toImport.length) { showToast('沒有可匯入的資料', 'error'); return; }

  // 詢問是覆蓋還是新增
  let mode = 'replace';
  if (rows.length > 0) {
    const choice = confirm('目前資料輸入已有 ' + rows.length + ' 筆資料\n\n點擊「確定」：清除並替換\n點擊「取消」：新增至現有資料後面');
    mode = choice ? 'replace' : 'append';
  }

  if (mode === 'replace') { rows = []; nextId = 1; }

  toImport.forEach(r => addRow({
    station:  r.station,
    start:    r.start,
    end:      r.end,
    progress: 0,
    note:     ''
  }));

  showToast(`已匯入 ${toImport.length} 筆資料`, 'success');

  // 收起貼上區並滾動至資料輸入
  togglePastePanel();
  document.getElementById('input-panel').scrollIntoView({ behavior: 'smooth', block: 'start' });

  // 自動產生甘特圖
  setTimeout(() => renderGantt(), 300);
}

// 清除貼上區
function clearPaste() {
  rawPastedRows = []; rawHeaders = []; parsedPreview = [];
  document.getElementById('paste-catcher').value = '';
  document.getElementById('paste-zone').classList.remove('has-content');
  document.getElementById('paste-zone').style.minHeight = '';
  document.getElementById('col-map-section').style.display = 'none';
  document.getElementById('paste-preview').style.display = 'none';
}

// 判斷字串是否為日期
function looksLikeDate(s) {
  if (!s) return false;
  // 匹配常見日期格式: M/D/YYYY, YYYY/MM/DD, YYYY-MM-DD, M/D/YY, Excel 序列數字
  return /^\d{1,2}\/\d{1,2}\/\d{2,4}$/.test(s) ||
         /^\d{4}[\/\-]\d{1,2}[\/\-]\d{1,2}$/.test(s) ||
         /^\d{4,5}$/.test(s);  // Excel 日期序列數
}

// 剖析 Excel 日期（支援多種格式）
function parseExcelDate(s) {
  if (!s) return null;
  s = s.trim();

  // Excel 序列數字（如 45000）
  if (/^\d{4,5}$/.test(s)) {
    const n = parseInt(s);
    if (n > 1000 && n < 100000) {
      // Excel 日期序列數轉換（基準日 1899/12/30）
      const d = new Date(1899, 11, 30);
      d.setDate(d.getDate() + n);
      return new Date(d.getFullYear(), d.getMonth(), d.getDate());
    }
  }

  // M/D/YYYY 或 M/D/YY
  const mdy = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})$/);
  if (mdy) {
    let y = parseInt(mdy[3]);
    if (y < 100) y += y < 30 ? 2000 : 1900;
    return new Date(y, parseInt(mdy[1])-1, parseInt(mdy[2]));
  }

  // YYYY/MM/DD 或 YYYY-MM-DD
  const ymd = s.match(/^(\d{4})[\/\-](\d{1,2})[\/\-](\d{1,2})$/);
  if (ymd) return new Date(parseInt(ymd[1]), parseInt(ymd[2])-1, parseInt(ymd[3]));

  // 嘗試直接解析
  const d = new Date(s);
  return isNaN(d) ? null : new Date(d.getFullYear(), d.getMonth(), d.getDate());
}

/* ── LocalStorage ───────────────────────────────────────── */
const LS_KEY = 'ganttTool_v1';

function saveToStorage() {
  try {
    getRowValues();
    const state = {
      rows,
      lang: currentLang,
      colWidth:    document.getElementById('col-width').value,
      rowHeight:   document.getElementById('row-height').value,
      dateFmt:     document.getElementById('date-fmt').value,
      showProgress: document.getElementById('show-progress').checked,
      showLabel:   document.getElementById('show-label').checked,
      showWeekend: document.getElementById('show-weekend').checked,
      autoRender,
      savedAt: new Date().toISOString()
    };
    localStorage.setItem(LS_KEY, JSON.stringify(state));
  } catch(e) { /* storage full or private mode */ }
}

function loadFromStorage() {
  try {
    const raw = localStorage.getItem(LS_KEY);
    if (!raw) return false;
    const state = JSON.parse(raw);
    if (!state || !Array.isArray(state.rows)) return false;

    // Restore rows
    rows = []; nextId = 1;
    state.rows.forEach(r => addRow(r));

    // Restore settings
    if (state.colWidth)  document.getElementById('col-width').value  = state.colWidth;
    if (state.rowHeight) document.getElementById('row-height').value = state.rowHeight;
    if (state.dateFmt)   document.getElementById('date-fmt').value   = state.dateFmt;
    document.getElementById('show-progress').checked = !!state.showProgress;
    document.getElementById('show-label').checked    = state.showLabel !== undefined ? !!state.showLabel : true;
    document.getElementById('show-weekend').checked  = state.showWeekend !== undefined ? !!state.showWeekend : true;
    autoRender = !!state.autoRender;
    updateAutoBtn();

    // Restore language
    if (state.lang && state.lang !== currentLang) toggleLang();

    return true;
  } catch(e) { return false; }
}

// Auto-save: on any row change or setting change
const _origAddRow    = addRow;
const _origRemoveRow = removeRow;
const _origOnInput   = onInput;

// Wrap renderGantt to trigger save after render
const _origRenderGantt = renderGantt;
renderGantt = function(...args) {
  _origRenderGantt(...args);
  saveToStorage();
};

// Also save on setting changes
['col-width','row-height','date-fmt'].forEach(id => {
  const el = document.getElementById(id);
  if (el) el.addEventListener('change', saveToStorage);
});
['show-progress','show-label','show-weekend'].forEach(id => {
  const el = document.getElementById(id);
  if (el) el.addEventListener('change', saveToStorage);
});

/* ── Init ────────────────────────────────────────────────── */
i18n = LANG.zh;
const restored = loadFromStorage();
if (!restored) loadSample();  // first-time: load sample data
else renderGantt();            // restored: re-render gantt with saved data</script>
