<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Gantt Chart Tool 甘特圖工具</title>
<style>
/* ── Reset ─────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --primary:       #2F5496;
  --primary-light: #4472C4;
  --primary-dark:  #1F3864;
  --accent:        #ED7D31;
  --success:       #70AD47;
  --danger:        #C00000;
  --warn:          #FFC000;
  --bg:            #F0F4FA;
  --card:          #FFFFFF;
  --border:        #D0D8E8;
  --text:          #1E2D45;
  --muted:         #6B7A99;
  --radius:        10px;
  --shadow:        0 4px 24px rgba(47,84,150,.12);
  --shadow-sm:     0 2px 8px rgba(47,84,150,.08);

  --bar0: #4472C4;
  --bar1: #3CB371;
  --bar2: #ED7D31;
  --bar3: #C00000;
  --bar4: #7030A0;
  --bar5: #00B0A0;
  --bar6: #D4A017;
  --bar7: #E75480;
}
body {
  font-family: "Segoe UI","Microsoft JhengHei","PingFang TC",Arial,sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  font-size: 14px;
  line-height: 1.6;
}

/* ── Top Bar ────────────────────────────────────────────── */
.topbar {
  background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 60%, var(--primary-light) 100%);
  color: #fff;
  padding: 0 32px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2px 12px rgba(0,0,0,.18);
  position: sticky;
  top: 0;
  z-index: 100;
}
.topbar-left { display: flex; align-items: center; gap: 14px; }
.topbar-logo {
  width: 36px; height: 36px;
  background: var(--accent);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 20px;
}
.topbar-title { font-size: 17px; font-weight: 800; letter-spacing: -.2px; }
.topbar-subtitle { font-size: 11px; opacity: .65; margin-top: 1px; }
.topbar-actions { display: flex; gap: 8px; }

/* ── Buttons ────────────────────────────────────────────── */
.btn {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 8px 18px; border-radius: 7px; border: none;
  font-size: 13.5px; font-weight: 600; cursor: pointer;
  transition: all .18s; white-space: nowrap; font-family: inherit;
}
.btn:hover { opacity: .88; transform: translateY(-1px); }
.btn:active { transform: translateY(0); opacity: 1; }
.btn-primary   { background: var(--primary);       color: #fff; }
.btn-success   { background: var(--success);        color: #fff; }
.btn-accent    { background: var(--accent);         color: #fff; }
.btn-danger    { background: var(--danger);         color: #fff; }
.btn-outline   { background: #fff; color: var(--primary); border: 1.5px solid var(--primary); }
.btn-ghost     { background: rgba(255,255,255,.15); color: #fff; border: 1px solid rgba(255,255,255,.3); }
.btn-ghost:hover { background: rgba(255,255,255,.25); }
.btn-sm        { padding: 5px 12px; font-size: 12.5px; }
.btn-icon      { padding: 7px 10px; }
.btn-warn      { background: var(--warn); color: #333; }

/* ── Layout ─────────────────────────────────────────────── */
.container { max-width: 1400px; margin: 0 auto; padding: 28px 28px 60px; }

/* ── Panel ──────────────────────────────────────────────── */
.panel {
  background: var(--card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  margin-bottom: 24px;
  overflow: hidden;
}
.panel-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 24px;
  border-bottom: 1px solid var(--border);
  background: #FAFBFD;
}
.panel-title {
  display: flex; align-items: center; gap: 10px;
  font-size: 15px; font-weight: 700; color: var(--primary);
}
.panel-icon {
  width: 32px; height: 32px; border-radius: 7px;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px;
}
.pi-blue   { background: #EBF3FB; }
.pi-green  { background: #EBF7EF; }
.pi-orange { background: #FEF3EB; }
.panel-body { padding: 20px 24px; }

/* ── Input Table ────────────────────────────────────────── */
.input-table-wrap { overflow-x: auto; margin-bottom: 14px; }
.input-table {
  width: 100%; border-collapse: collapse;
  font-size: 13.5px; min-width: 560px;
}
.input-table thead tr { background: var(--primary); color: #fff; }
.input-table thead th {
  padding: 10px 14px; text-align: left;
  font-weight: 600; white-space: nowrap;
}
.input-table thead th:first-child { width: 44px; text-align: center; }
.input-table thead th:last-child  { width: 52px; text-align: center; }
.input-table tbody tr { transition: background .12s; }
.input-table tbody tr:nth-child(even) { background: #F7F9FD; }
.input-table tbody tr:hover { background: #EBF3FB; }
.input-table tbody td { border-bottom: 1px solid var(--border); padding: 0; }
.input-table tbody td.td-num {
  text-align: center; color: var(--muted);
  font-size: 12px; padding: 8px 6px;
  font-weight: 600;
}
.input-table tbody td.td-action { text-align: center; padding: 4px; }
.input-table input[type="text"],
.input-table input[type="date"] {
  width: 100%; padding: 9px 12px;
  border: none; background: transparent;
  font-size: 13.5px; font-family: inherit;
  color: var(--text); outline: none;
  transition: background .12s;
}
.input-table input:focus { background: #EBF3FB; }
.input-table input.error { background: #FFEBEB !important; }
.input-table input::placeholder { color: #B0BBCC; }

.del-btn {
  background: none; border: none; cursor: pointer;
  color: #CCC; font-size: 18px; line-height: 1;
  padding: 4px 8px; border-radius: 5px;
  transition: color .15s, background .15s;
}
.del-btn:hover { color: var(--danger); background: #FFEBEB; }

.add-row-btn {
  width: 100%; padding: 9px;
  background: none; border: 1.5px dashed var(--border);
  border-radius: 7px; color: var(--muted);
  font-size: 13px; cursor: pointer; font-family: inherit;
  display: flex; align-items: center; justify-content: center; gap: 6px;
  transition: border-color .15s, color .15s, background .15s;
}
.add-row-btn:hover { border-color: var(--primary); color: var(--primary); background: #EBF3FB; }

/* ── Action Bar ─────────────────────────────────────────── */
.action-bar {
  display: flex; align-items: center; gap: 10px;
  flex-wrap: wrap; padding: 14px 24px;
  border-top: 1px solid var(--border);
  background: #FAFBFD;
}
.action-bar-right { margin-left: auto; display: flex; gap: 8px; }

/* ── Settings Row ───────────────────────────────────────── */
.settings-row {
  display: flex; align-items: center; gap: 20px;
  flex-wrap: wrap; padding: 14px 24px;
  border-bottom: 1px solid var(--border);
  background: #FAFBFD; font-size: 13px;
}
.setting-item { display: flex; align-items: center; gap: 8px; }
.setting-item label { color: var(--muted); font-weight: 600; white-space: nowrap; }
.setting-item select,
.setting-item input[type="number"] {
  padding: 5px 10px; border: 1.5px solid var(--border);
  border-radius: 6px; font-size: 13px; font-family: inherit;
  color: var(--text); background: #fff; outline: none;
  transition: border-color .15s;
}
.setting-item select:focus,
.setting-item input[type="number"]:focus { border-color: var(--primary-light); }
.setting-item input[type="checkbox"] {
  width: 16px; height: 16px; cursor: pointer; accent-color: var(--primary);
}

/* ── Gantt Chart ────────────────────────────────────────── */
#gantt-container {
  overflow-x: auto;
  overflow-y: visible;
  position: relative;
}
#gantt-container.empty {
  display: flex; align-items: center; justify-content: center;
  min-height: 200px; color: var(--muted);
  font-size: 14px; flex-direction: column; gap: 10px;
}
#gantt-container.empty .empty-icon { font-size: 40px; opacity: .4; }

.gantt-table {
  border-collapse: collapse;
  width: max-content;
  min-width: 100%;
  font-size: 12.5px;
}

/* Header */
.gantt-table .gh-month {
  background: var(--primary-dark); color: #fff;
  padding: 6px 8px; text-align: center;
  font-weight: 700; font-size: 11.5px;
  border-right: 1px solid rgba(255,255,255,.2);
  white-space: nowrap;
}
.gantt-table .gh-day {
  padding: 5px 2px; text-align: center;
  font-size: 11px; font-weight: 700;
  min-width: 28px; max-width: 28px; width: 28px;
  white-space: nowrap;
  border-right: 1px solid rgba(255,255,255,.2);
  user-select: none;
}
.gh-day.workday  { background: var(--primary);       color: #fff; }
.gh-day.weekend  { background: #8899AA;               color: #fff; }
.gh-day.today-hd { background: var(--danger) !important; color: #fff !important; }

/* Label column */
.gantt-table .gl {
  padding: 0 16px; font-size: 13px; font-weight: 600;
  white-space: nowrap; background: #F2F5FB;
  border-right: 2px solid var(--border);
  border-bottom: 1px solid var(--border);
  min-width: 180px; max-width: 240px;
  position: sticky; left: 0; z-index: 2;
  height: 36px; vertical-align: middle;
  overflow: hidden; text-overflow: ellipsis;
}
.gantt-table .gl-header {
  background: var(--primary); color: #fff; font-weight: 700;
  font-size: 12px; padding: 0 16px;
  position: sticky; left: 0; z-index: 4;
  height: 28px; vertical-align: middle;
  border-right: 2px solid rgba(255,255,255,.3);
  white-space: nowrap;
}
.gantt-table .gl-month-header {
  background: var(--primary); color: #fff;
  position: sticky; left: 0; z-index: 4;
  border-right: 2px solid rgba(255,255,255,.3);
}

/* Data cells */
.gantt-table .gc {
  border-right: 1px solid #E4EAF4;
  border-bottom: 1px solid #E4EAF4;
  min-width: 28px; max-width: 28px; width: 28px;
  height: 36px; padding: 0;
  position: relative; vertical-align: middle;
}
.gc.weekend-col { background: #F0F2F5; }
.gc.today-col   { border-right: 2px solid rgba(192,0,0,.5) !important; }

/* Bar */
.gantt-bar {
  position: absolute;
  top: 5px; bottom: 5px;
  border-radius: 4px;
  display: flex; align-items: center;
  color: #fff; font-size: 11px; font-weight: 700;
  white-space: nowrap; overflow: hidden;
  padding: 0 6px;
  box-shadow: 0 1px 4px rgba(0,0,0,.2);
  cursor: pointer;
  transition: filter .15s, top .15s, bottom .15s;
  z-index: 1;
}
.gantt-bar:hover { filter: brightness(1.15); top: 3px; bottom: 3px; }

/* Today line */
.today-line-row td.today-col::after {
  content: '';
  position: absolute;
  top: 0; bottom: 0; right: -1px;
  width: 2px;
  background: rgba(192,0,0,.4);
  pointer-events: none;
}

/* ── Progress bar in bar ─────────────────────────────────── */
.bar-progress {
  position: absolute; top: 0; left: 0; bottom: 0;
  background: rgba(0,0,0,.18); border-radius: 4px 0 0 4px;
  pointer-events: none;
}

/* ── Tooltip ────────────────────────────────────────────── */
.gantt-tooltip {
  position: fixed; z-index: 9999;
  background: rgba(20,30,50,.92);
  color: #fff; border-radius: 8px;
  padding: 10px 14px; font-size: 12.5px;
  pointer-events: none; opacity: 0;
  transition: opacity .15s;
  max-width: 240px; line-height: 1.7;
  box-shadow: 0 4px 20px rgba(0,0,0,.3);
}
.gantt-tooltip.show { opacity: 1; }
.gantt-tooltip strong { color: var(--warn); }

/* ── Legend ─────────────────────────────────────────────── */
.gantt-legend {
  display: flex; flex-wrap: wrap; gap: 12px;
  padding: 12px 20px; background: #FAFBFD;
  border-top: 1px solid var(--border);
  font-size: 12.5px;
}
.legend-item { display: flex; align-items: center; gap: 6px; cursor: pointer; }
.legend-dot  { width: 14px; height: 14px; border-radius: 3px; flex-shrink: 0; }
.legend-item.dimmed { opacity: .35; }

/* ── Stats Bar ──────────────────────────────────────────── */
.stats-bar {
  display: flex; gap: 20px; flex-wrap: wrap;
  padding: 14px 24px; border-bottom: 1px solid var(--border);
  background: #FAFBFD;
}
.stat-item { display: flex; flex-direction: column; gap: 2px; }
.stat-label { font-size: 11px; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: .06em; }
.stat-value { font-size: 18px; font-weight: 800; color: var(--primary); }
.stat-value.accent { color: var(--accent); }
.stat-value.success { color: var(--success); }
.stat-value.danger  { color: var(--danger); }

/* ── Progress Col ───────────────────────────────────────── */
.td-progress { padding: 0 14px; min-width: 120px; vertical-align: middle; }
.progress-bg {
  background: #E4EAF4; border-radius: 4px; height: 8px; overflow: hidden;
}
.progress-fill { height: 100%; border-radius: 4px; transition: width .4s; }
.progress-label { font-size: 11px; color: var(--muted); margin-top: 2px; text-align: right; }

/* ── Toast ──────────────────────────────────────────────── */
.toast-container {
  position: fixed; bottom: 28px; right: 28px;
  display: flex; flex-direction: column; gap: 8px;
  z-index: 9999;
}
.toast {
  background: #1E2D45; color: #fff;
  padding: 12px 20px; border-radius: 8px;
  font-size: 13.5px; box-shadow: 0 4px 20px rgba(0,0,0,.25);
  display: flex; align-items: center; gap: 10px;
  animation: slideIn .25s ease;
  max-width: 320px;
}
.toast.success { border-left: 4px solid var(--success); }
.toast.error   { border-left: 4px solid var(--danger); }
.toast.info    { border-left: 4px solid var(--primary-light); }
@keyframes slideIn {
  from { transform: translateX(60px); opacity: 0; }
  to   { transform: translateX(0);    opacity: 1; }
}

/* ── Modal ──────────────────────────────────────────────── */
.modal-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,.45);
  display: flex; align-items: center; justify-content: center;
  z-index: 1000; opacity: 0; pointer-events: none;
  transition: opacity .2s;
}
.modal-overlay.show { opacity: 1; pointer-events: all; }
.modal {
  background: #fff; border-radius: var(--radius);
  box-shadow: 0 20px 60px rgba(0,0,0,.25);
  padding: 28px 32px; max-width: 480px; width: 90%;
  transform: translateY(20px); transition: transform .2s;
}
.modal-overlay.show .modal { transform: translateY(0); }
.modal h3 { font-size: 17px; font-weight: 800; color: var(--primary); margin-bottom: 14px; }
.modal p  { font-size: 13.5px; color: #555; line-height: 1.7; margin-bottom: 20px; }
.modal-actions { display: flex; gap: 10px; justify-content: flex-end; }

/* ── Import Textarea ────────────────────────────────────── */
.import-textarea {
  width: 100%; height: 160px; padding: 12px;
  border: 1.5px solid var(--border); border-radius: 7px;
  font-family: "Consolas","Courier New",monospace;
  font-size: 12.5px; resize: vertical; outline: none;
  transition: border-color .15s; color: var(--text);
}
.import-textarea:focus { border-color: var(--primary-light); }
.import-hint { font-size: 12px; color: var(--muted); margin-top: 6px; line-height: 1.6; }

/* ── Responsive ─────────────────────────────────────────── */
@media (max-width: 640px) {
  .container { padding: 16px 12px 40px; }
  .topbar { padding: 0 16px; }
  .topbar-subtitle { display: none; }
  .panel-body { padding: 14px 14px; }
  .action-bar { padding: 12px 14px; }
  .stats-bar { padding: 12px 14px; gap: 14px; }
}

/* ── Date Wrapper — custom calendar button on the LEFT ──── */
.date-wrap {
  display: flex;
  align-items: center;
  width: 100%;
  position: relative;
}
.date-wrap input[type="date"] {
  flex: 1;
  padding: 9px 8px 9px 36px;   /* leave room for the button */
  direction: ltr;
  min-width: 0;
}
/* Hide the browser's native calendar icon completely */
.date-wrap input[type="date"]::-webkit-calendar-picker-indicator {
  opacity: 0;
  width: 0;
  padding: 0;
  margin: 0;
}
/* Custom calendar button sits on the LEFT inside the wrapper */
.date-cal-btn {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 34px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  border-right: 1px solid var(--border);
  cursor: pointer;
  color: var(--primary-light);
  font-size: 15px;
  border-radius: var(--radius) 0 0 var(--radius);
  transition: background .15s;
  z-index: 1;
}
.date-cal-btn:hover { background: #EBF2FB; }

/* ── Excel Paste Panel ─────────────────────────────────── */
.paste-zone {
  position: relative;
  border: 2.5px dashed var(--border);
  border-radius: 8px;
  background: #FAFBFD;
  transition: border-color .2s, background .2s;
  min-height: 120px;
  cursor: text;
}
.paste-zone:focus-within,
.paste-zone.drag-over {
  border-color: var(--primary-light);
  background: #EBF3FB;
}
.paste-zone-inner {
  display: flex; align-items: center; justify-content: center;
  flex-direction: column; gap: 8px;
  padding: 28px 20px;
  pointer-events: none;
  position: absolute; inset: 0;
  transition: opacity .2s;
}
.paste-zone-inner .pz-icon { font-size: 32px; opacity: .4; }
.paste-zone-inner .pz-title { font-size: 14px; font-weight: 700; color: var(--primary); }
.paste-zone-inner .pz-sub   { font-size: 12.5px; color: var(--muted); text-align: center; line-height: 1.6; }
.paste-zone.has-content .paste-zone-inner { opacity: 0; pointer-events: none; }

/* hidden contenteditable catcher */
.paste-catcher {
  position: absolute; inset: 0;
  opacity: 0;
  width: 100%; height: 100%;
  cursor: default;
  z-index: 2;
}

/* Preview table */
.preview-wrap { overflow-x: auto; }
.preview-table {
  width: 100%; border-collapse: collapse;
  font-size: 13px;
}
.preview-table thead tr { background: #E8EDF8; }
.preview-table thead th {
  padding: 8px 12px; text-align: left;
  font-weight: 700; color: var(--primary);
  border-bottom: 2px solid var(--border);
  white-space: nowrap;
}
.preview-table tbody tr:nth-child(even) { background: #F7F9FD; }
.preview-table tbody tr:hover { background: #EBF3FB; }
.preview-table tbody td {
  padding: 7px 12px;
  border-bottom: 1px solid var(--border);
  font-size: 13px;
}
.preview-table .td-station { font-weight: 600; }
.preview-table .td-date    { color: var(--primary); font-family: "Consolas",monospace; font-size: 12.5px; }
.preview-table .td-empty   { color: #CCC; font-style: italic; }
.preview-table .td-warn    { color: var(--accent); }
.preview-table .row-ok     td:first-child { border-left: 3px solid var(--success); }
.preview-table .row-warn   td:first-child { border-left: 3px solid var(--accent); }
.preview-table .row-skip   { opacity: .45; }
.preview-table .row-skip   td:first-child { border-left: 3px solid #CCC; }

.parse-summary {
  display: flex; gap: 16px; flex-wrap: wrap;
  padding: 10px 0 4px;
  font-size: 12.5px;
}
.ps-item { display: flex; align-items: center; gap: 5px; }
.ps-dot  { width: 10px; height: 10px; border-radius: 2px; }

.col-map-row {
  display: flex; align-items: center; gap: 10px;
  flex-wrap: wrap; margin-bottom: 14px;
  font-size: 13px;
}
.col-map-row label { color: var(--muted); font-weight: 600; white-space: nowrap; }
.col-map-row select {
  padding: 5px 10px; border: 1.5px solid var(--border);
  border-radius: 6px; font-size: 13px; font-family: inherit;
  color: var(--text); background: #fff; outline: none;
  min-width: 120px;
}

/* ── Print ──────────────────────────────────────────── */
@media print {
  .topbar, .action-bar, .settings-row, .panel-header .btn,
  .add-row-btn, .del-btn, .toast-container, .modal-overlay { display: none !important; }
  body { background: #fff; }
  .panel { box-shadow: none; border: 1px solid #ccc; }
  #gantt-container { overflow: visible !important; }
  .gantt-table { width: 100% !important; }
}
</style>
</head>
<body>

<!-- ── Top Bar ────────────────────────────────────────────── -->
<div class="topbar">
  <div class="topbar-left">
    <div class="topbar-logo">📊</div>
    <div>
      <div class="topbar-title">Gantt Chart Tool 甘特圖工具</div>
      <div class="topbar-subtitle" data-i18n="subtitle">Gantt Chart Tool 甘特圖工具 · HTML 版 · v1.13 · 2026-04-20</div>
    </div>
  </div>
  <div class="topbar-actions">
    <button class="btn btn-ghost btn-sm" onclick="openImport()" data-i18n="btn_import">⬆ 匯入</button>
    <button class="btn btn-ghost btn-sm" onclick="exportCSV()" data-i18n="btn_export_csv">⬇ 匯出 CSV</button>
    <button class="btn btn-ghost btn-sm" onclick="exportPNG()" data-i18n="btn_export_png">🖼 匯出 PNG</button>
    <button class="btn btn-ghost btn-sm" onclick="toggleLang()" id="lang-btn">EN</button>
  </div>
</div>

<!-- ── Main Container ─────────────────────────────────────── -->
<div class="container">
  <!-- ── Excel Paste Panel ──────────────────────────────────────── -->
  <div class="panel" id="paste-panel">
    <div class="panel-header">
      <div class="panel-title">
        <div class="panel-icon" style="background:#EBF7EF;">📥</div>
        <span data-i18n="panel_paste">從 Excel 貼上資料</span>
      </div>
      <div style="display:flex;gap:8px;align-items:center;">
        <span style="font-size:12px;color:var(--muted);">(可收起)</span>
