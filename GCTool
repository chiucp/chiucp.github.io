  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.dataset.i18n;
    if (L[key] !== undefined) el.textContent = L[key];
  });

  // Paste panel step hints
  const steps = document.querySelectorAll('#paste-panel-body > div:first-child > div');
  const stepTexts = [L.paste_step1, L.paste_step2, L.paste_step3, L.paste_step4];
  steps.forEach((el, i) => {
    const span = el.querySelector('span');
    if (span) el.childNodes[el.childNodes.length-1].textContent = ' ' + (stepTexts[i]||'');
  });

  // Paste zone text
